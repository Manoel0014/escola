generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Professor {
  id       Int      @id @default(autoincrement())
  nome     String
  email    String   @unique
  password String
  turmas   Turma[]
}

model Aluno {
  id        Int     @id @default(autoincrement())
  nome      String
  sobrenome String
  turmas    Turma[] @relation("AlunoTurma")
}

model Turma {
  id          Int       @id @default(autoincrement())
  nomeTurma   String
  professorId Int
  professor   Professor @relation(fields: [professorId], references: [id])
  alunos      Aluno[]   @relation("AlunoTurma")
}